            "description": "19 条准则的逐条判定，键与 TASK_IMPLEMENTATION_RUBRIC.toml 中 name 一致",
            "properties": {
              "verifiable": {
                "type": "object",
                "description": "验证方式可靠、确定性、可重复",
                "properties": {
                  "outcome": {
                    "type": "string",
                    "enum": ["PASS", "FAIL", "N/A"]
                  },
                  "explanation": {
                    "type": "string",
                    "description": "1～3 句理由"
                  }
                },
                "required": ["outcome", "explanation"]
              },
              "well_specified": {
                "type": "object",
                "description": "题面完整、无歧义地描述测试会检查的内容",
