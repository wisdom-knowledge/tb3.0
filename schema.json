                  "outcome": {
                    "type": "string",
                    "enum": ["PASS", "FAIL", "N/A"]
                  },
                  "explanation": {
                    "type": "string",
                    "description": "1～3 句理由"
                  }
                },
                "required": ["outcome", "explanation"]
              },
              "solvable": {
                "type": "object",
                "description": "存在可通过全部测试的参考解法，且专家数小时内可实现",
                "properties": {
                  "outcome": {
                    "type": "string",
                    "enum": ["PASS", "FAIL", "N/A"]
                  },
                  "explanation": {
                    "type": "string",
                    "description": "1～3 句理由"
                  }
