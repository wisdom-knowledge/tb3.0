{
  "name": "rubrics_review_result",
  "description": "Terminal Bench 3.0 任务实现审核输出结构，含审查建议与结构化判定；准则与 TASK_IMPLEMENTATION_RUBRIC.toml 一一对应",
  "parameters": {
    "type": "object",
