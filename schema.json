          "review_suggestions": {
            "type": "string",
            "description": "审查建议（必选）：写给任务作者的自然语言建议，含整体评价、未通过项说明、优先改进建议等，中文"
          },
          "task_path": {
            "type": "string",
            "description": "任务目录相对路径，如 tasks/hello-world"
          },
          "criteria": {
